# ─────────────────────────────────────────────
# SYNLO — ENVIRONMENT VARIABLES
# Copy to .env.local and fill in your values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── FLUTTERWAVE ───────────────────────────────
# Get from: https://dashboard.flutterwave.com → Settings → API
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key_here
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash_secret_here
# Webhook URL to register in Flutterwave dashboard:
# https://yourdomain.com/api/webhooks/flutterwave

# ── APP CONFIG ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Synlo

# ── EMAIL (Resend — recommended) ──────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=noreply@synlo.ng

# ── STORAGE (Supabase Storage handles this) ───
# Bucket name in Supabase Storage
NEXT_PUBLIC_STORAGE_BUCKET=synlo-assets

# ─────────────────────────────────────────────
# SETUP CHECKLIST
# ─────────────────────────────────────────────
# 1. Create Supabase project at https://app.supabase.com
# 2. Run /supabase/migrations/001_initial_schema.sql in SQL Editor
# 3. Create storage bucket: "synlo-assets" (public)
# 4. Enable Email auth in Supabase Auth settings
# 5. Create Flutterwave account at https://flutterwave.com
# 6. Register webhook: /api/webhooks/flutterwave
# 7. Create Resend account and verify domain
# 8. Deploy to Vercel and set env vars
